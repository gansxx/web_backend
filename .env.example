############
# Database - You can change these to any PostgreSQL database that has logical replication enabled.
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# PostgreSQL 宿主机端口 (Docker端口转发，外部连接使用)
POSTGRES_PORT_LOCAL=5438
# default user is postgres


############
# Supavisor -- Database pooler
############
# Port Supavisor listens on for transaction pooling connections
POOLER_PROXY_PORT_TRANSACTION=6543
# Maximum number of PostgreSQL connections Supavisor opens per pool
POOLER_DEFAULT_POOL_SIZE=20
# Maximum number of client connections Supavisor accepts per pool
POOLER_MAX_CLIENT_CONN=100
# Unique tenant identifier
POOLER_TENANT_ID=your-tenant-id
# Pool size for internal metadata storage used by Supavisor
# This is separate from client connections and used only by Supavisor itself
POOLER_DB_POOL_SIZE=5


############
# API Proxy - Configuration for the Kong Reverse proxy.
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443


############
# API - Configuration for PostgREST.
############

PGRST_DB_SCHEMAS=public,storage,graphql_public


############
# Auth - Configuration for the GoTrue authentication server.
############

## General
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=http://localhost:8000

## Mailer Config
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

## Email auth
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

## Phone auth
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

## Webhooks - New user notification
# Webhook URL for new user registration notifications
# See docs/WEBHOOK_NOTIFICATION_SETUP.md for available notification services
# Examples:
#   Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
#   Server Chan: https://sctapi.ftqq.com/<SendKey>.send
#   Bark: https://api.day.app/<DEVICE_KEY>/
USER_WEBHOOK_URL=


############
# Studio - Configuration for the Dashboard
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

STUDIO_PORT=3000
# replace if you intend to use Studio outside of localhost
SUPABASE_PUBLIC_URL=http://localhost:8000

# Enable webp support
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Add your OpenAI API key to enable SQL Editor Assistant
OPENAI_API_KEY=


############
# Functions - Configuration for Functions
############
# NOTE: VERIFY_JWT applies to all functions. Per-function VERIFY_JWT is not supported yet.
FUNCTIONS_VERIFY_JWT=false


############
# Logs - Configuration for Analytics
# Please refer to https://supabase.com/docs/reference/self-hosting-analytics/introduction
############

# Change vector.toml sinks to reflect this change
# these cannot be the same value
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private

# Docker socket location - this value will differ depending on your OS
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Google Cloud Project details
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER


############
# Cloudflare R2 Storage - Configuration for package distribution
############

# Cloudflare Account ID (required)
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 Access Credentials (required)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 Bucket Configuration (required)
R2_BUCKET_NAME=software-packages

# R2 Endpoint URL (optional - auto-generated from account ID if not provided)
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# Custom Public Domain (optional - for custom domain access)
# If configured, presigned URLs will use this domain instead of R2 endpoint
# Example: https://packages.yourdomain.com
R2_PUBLIC_DOMAIN=

# Package Management Configuration
R2_MAX_PACKAGE_SIZE_MB=500
R2_DOWNLOAD_URL_EXPIRY_SECONDS=3600

# Auto-cleanup Configuration (optional)
R2_ENABLE_AUTO_CLEANUP=false
R2_CLEANUP_DAYS_THRESHOLD=90


############
# Stripe Payment Configuration
############

# Stripe API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx


############
# H5Zhifu Payment Configuration (中国支付网关)
############

# H5Zhifu Merchant Credentials
H5ZHIFU_APP_ID=your_app_id_here
H5ZHIFU_SECRET_KEY=your_secret_key_here

# H5Zhifu Payment Settings
H5ZHIFU_PAY_TYPE=alipay  # Options: alipay (支付宝) or wechat (微信支付)
H5ZHIFU_NOTIFY_URL=https://api.selfgo.asia/webhook/h5zhifu/advanced-plan


############
# Advanced Plan Configuration
############

# Advanced Plan Pricing (amount in cents)
ADVANCED_PLAN_PRICE=9900  # 99元 * 100分 = 9900分
ADVANCED_PLAN_CURRENCY=usd  # or 'cny' for Chinese Yuan

# Webhook Configuration
WEBHOOK_BASE_URL=https://api.selfgo.asia


############
# Unlimited Plan Configuration
############

# Unlimited Plan Pricing (amount in cents)
UNLIMITED_PLAN_PRICE=29900  # 299元 * 100分 = 29900分
UNLIMITED_PLAN_CURRENCY=cny  # Chinese Yuan

# Unlimited Plan Gateway
# 无限流量套餐使用独立的网关服务器
unlimited_gateway_ip=your_unlimited_gateway_ip_here


############
# DNS Resolution Configuration
############

# DNS Servers (comma-separated, in priority order)
# Default: 114.114.114.114 (China Telecom Public DNS, primary), 8.8.8.8 (Google DNS, backup)
# The system bypasses local DNS cache and queries these servers directly
DNS_SERVERS=114.114.114.114,8.8.8.8

# DNS Query Timeout (seconds)
# Maximum time to wait for a single DNS query response
DNS_QUERY_TIMEOUT=5

# DNS Retry Configuration
# Number of retry attempts for DNS queries (useful for DNS propagation delays)
DNS_RETRY_ATTEMPTS=3

# Interval between retry attempts (seconds)
DNS_RETRY_INTERVAL=2
