# =====================================================
# 阿里云 Function Compute 部署所需环境变量
# =====================================================
# 说明：将以下变量添加到项目根目录的 .env 文件中
# =====================================================

# =====================================================
# 阿里云认证（必需）
# =====================================================

ALICLOUD_ACCESS_KEY=LTAI5t...
ALICLOUD_SECRET_KEY=your-secret-key

# =====================================================
# 阿里云容器镜像服务 ACR（必需）
# =====================================================

# ACR 注册表地址（根据区域选择）
# 华南1（深圳）: registry.cn-shenzhen.aliyuncs.com
# 华东1（杭州）: registry.cn-hangzhou.aliyuncs.com
# 华东2（上海）: registry.cn-shanghai.aliyuncs.com
# 华北2（北京）: registry.cn-beijing.aliyuncs.com
ACR_REGISTRY=registry.cn-shenzhen.aliyuncs.com

# ACR 命名空间（需要在 ACR 控制台创建）
ACR_NAMESPACE=your-namespace

# =====================================================
# 镜像配置（可选，有默认值）
# =====================================================

IMAGE_NAME=web-backend
IMAGE_TAG=latest
PLATFORM=linux/amd64

# =====================================================
# 区域配置（可选）
# =====================================================

REGION=cn-shenzhen

# =====================================================
# 现有环境变量（确保已配置）
# =====================================================

# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
ANON_KEY=eyJhbG...
SERVICE_ROLE_KEY=eyJhbG...

# 数据库
POSTGRES_PASSWORD=your-postgres-password

# JWT
JWT_SECRET=your-jwt-secret

# 前端
FRONTEND_URL=https://app.selfgo.asia

# Turnstile（可选）
TURNSTILE_SECRET_KEY=0x4AAA...

# Cloudflare DNS（可选）
cloudflare_dns_key=your-cloudflare-api-token
