#============================================
# 数据库迁移工具配置示例
#============================================
#
# 使用说明:
# 1. 复制此文件为 .env.migration
# 2. 根据你的实际环境填入正确的配置值
# 3. 运行迁移工具: uv run python center_management/db/migration/pg_dump_remote.py
#
# 注意: 此文件只包含数据库迁移必需的配置参数
#

#============================================
# 远程数据库连接配置 (必需)
#============================================

# 网关IP地址 - 用于通过网关访问远程数据库
# 示例: remote_db_ip='192.168.1.100' 或 remote_db_ip='vpn.example.com'
# 远程数据库IP地址 (必需)
remote_db_ip='your_remote_db_ip_or_hostname'

# PostgreSQL 数据库密码 (必需)
# 注意: 这个密码必须与远程数据库的 postgres 用户密码一致
REMOTE_POSTGRES_PASSWORD=your_remote_postgres_password

# 数据库名称 (可选，默认: postgres)
REMOTE_POSTGRES_DB=postgres

# 数据库主机名 (可选)
# 直接连接模式: 使用容器化部署时通常是 'db'
# SSH隧道模式: 应该设置为 '127.0.0.1' 或 'localhost'，因为隧道在SSH网关机器上建立
# 示例: REMOTE_POSTGRES_HOST=127.0.0.1 (SSH隧道) 或 REMOTE_POSTGRES_HOST=db (直接连接)
REMOTE_POSTGRES_HOST=127.0.0.1

# 数据库暴露端口 (远程)
REMOTE_POSTGRES_PORT=5438

# 本地转发端口 (SSH隧道模式下使用)
LOCAL_remote_POSTGRES_PORT=5439

#============================================
# SSH隧道配置 (可选 - 用于通过SSH网关访问远程数据库)
#============================================

# 是否启用SSH隧道 (true/false)
# 启用后将通过SSH端口转发连接远程数据库，无需直接暴露数据库端口
USE_SSH_TUNNEL=false

# SSH网关主机 (SSH跳板机或远程服务器IP)
# 可以与remote_db_ip相同，也可以是专门的跳板机
SSH_GATEWAY_HOST=your_ssh_gateway_host

# SSH网关端口 (默认: 22)
SSH_GATEWAY_PORT=22

# SSH网关用户名 (默认: root)
SSH_GATEWAY_USER=root

# SSH私钥文件路径 (建议使用绝对路径或相对项目根目录的路径)
# 示例: ./center_management/id_ed25519 或 ~/.ssh/id_rsa
SSH_KEY_FILE=./center_management/id_ed25519

