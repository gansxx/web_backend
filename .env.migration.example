#============================================
# 数据库迁移工具配置示例
#============================================
#
# 使用说明:
# 1. 复制此文件为 .env.migration
# 2. 根据你的实际环境填入正确的配置值
# 3. 运行迁移工具: uv run python center_management/db/migration/pg_dump_remote.py
#
# 注意: 此文件只包含数据库迁移必需的配置参数
#

#============================================
# 远程数据库连接配置 (必需)
#============================================

# 网关IP地址 - 用于通过网关访问远程数据库
# 示例: gateway_ip='192.168.1.100' 或 gateway_ip='vpn.example.com'
gateway_ip='YOUR_GATEWAY_IP_HERE'

# PostgreSQL 数据库密码 (必需)
# 注意: 这个密码必须与远程数据库的 postgres 用户密码一致
POSTGRES_PASSWORD=your_remote_postgres_password

# 数据库名称 (可选，默认: postgres)
POSTGRES_DB=postgres

# 数据库主机名 (可选，通常不需要修改)
# 对于容器化部署，通常是 'db'
POSTGRES_HOST=db

# 数据库端口 (可选，默认: 5432)
# 注意: 这是远程服务器内部的 PostgreSQL 端口，不是网关映射的端口
POSTGRES_PORT=5432

#============================================
# 连接配置说明
#============================================
#
# 本工具的连接方式:
# - 远程数据库: 通过 gateway_ip:5438 连接到远程数据库
# - 本地数据库: 通过 localhost:5438 连接到本地 Docker 数据库
#
# 端口映射:
# - 5438: 对外暴露的端口 (本地 Docker 或远程网关)
# - 5432: PostgreSQL 容器内部端口
#

#============================================
# 可选配置 (仅在使用 Supabase API 时需要)
#============================================

# 前端/API URL (可选)
# 如果你需要通过 Supabase API 访问，请填入正确的 URL
# FRONTEND_URL=https://your-domain.com

# Supabase 匿名密钥 (可选)
# ANON_KEY=your_anon_key_here

# Supabase 服务角色密钥 (可选)
# SERVICE_ROLE_KEY=your_service_role_key_here

#============================================
# 使用示例
#============================================
#
# 1. 测试连接:
#    uv run python center_management/db/migration/pg_dump_remote.py --test
#
# 2. 从远程同步到本地 (最常用):
#    uv run python center_management/db/migration/pg_dump_remote.py --sync --source remote --target local --clean
#
# 3. 导出远程数据库:
#    uv run python center_management/db/migration/pg_dump_remote.py --export --source remote
#
# 4. 查看所有备份文件:
#    uv run python center_management/db/migration/pg_dump_remote.py --list
#

#============================================
# 故障排除
#============================================
#
# 常见问题:
#
# 1. 连接超时或连接被拒绝:
#    - 检查 gateway_ip 是否正确
#    - 确认远程服务器防火墙允许 5438 端口
#    - 验证网络连通性: ping gateway_ip
#
# 2. 认证失败:
#    - 检查 POSTGRES_PASSWORD 是否正确
#    - 确认远程数据库的 postgres 用户密码
#
# 3. 数据库不存在:
#    - 检查 POSTGRES_DB 设置
#    - 确认远程数据库中存在指定的数据库
#
# 4. 权限错误:
#    - 确认 postgres 用户有足够的权限
#    - 检查数据库的访问控制设置
#

#============================================
# 安全提醒
#============================================
#
# 重要:
# - 此文件包含敏感的数据库密码，请不要提交到版本控制系统
# - 建议将 .env.migration 添加到 .gitignore 文件中
# - 在生产环境中，确保文件权限设置为 600 (仅所有者可读写)
#   命令: chmod 600 .env.migration
#